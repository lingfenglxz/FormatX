{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FormatX",
  "version": "0.1.0",
  "identifier": "com.lingfenglxz.formatx",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm.cmd run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FormatX",
        "width": 1200,
        "height": 760,
        "minWidth": 860,
        "minHeight": 560
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico"],
    "targets": ["nsis", "msi"]
  }
}
